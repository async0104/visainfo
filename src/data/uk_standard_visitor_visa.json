    },
    {
      "id": "long_term_2yr",
      "name": "长期标准访客签证（2年）",
      "fee_gbp": 506,
      "max_stay_per_visit": "每次最长6个月",
      "validity": "2年",
      "note": "适合频繁访英人士"
    },
    {
      "id": "long_term_5yr",
      "name": "长期标准访客签证（5年）",
      "fee_gbp": 903,
      "max_stay_per_visit": "每次最长6个月",
      "validity": "5年"
    },
    {
      "id": "long_term_10yr",
      "name": "长期标准访客签证（10年）",
      "fee_gbp": 1128,
      "max_stay_per_visit": "每次最长6个月",
      "validity": "10年"
    }
  ],

  "required_docs": [
    {
      "item": "有效护照或旅行证件",
      "required": true,
      "note": "护照须在整个英国停留期间有效"
    },
    {
      "item": "在线申请表中填写的信息",
      "required": true,
      "includes": [
        "计划赴英日期",
        "在英住宿地址",
        "预计旅行费用",
        "现居住地址及居住时长",
        "父母姓名和出生日期（如知晓）",
        "年收入（如有）",
        "任何刑事、民事或移民违规记录"
      ]
    }
  ],

  "additional_docs_by_situation": [
    {
      "situation": "所有申请人（视情况可能需要）",
      "docs": [
        "过去10年的出行记录",
        "雇主地址和电话",
        "配偶/伴侣的姓名、出生日期和护照号码",
        "资助人的姓名和地址（如由他人支付旅行费用）",
        "在英家庭成员的姓名、地址和护照号码"
      ]
    },
    {
      "situation": "停留超过6个月",
      "docs": ["结核病（TB）检测证明"]
    },
    {
      "situation": "赴英学习",
      "docs": [
        "学校/机构录取通知书",
        "课程详情（时长、内容）"
      ]
    },
    {
      "situation": "学术访问",
      "docs": [
        "英国接待机构的邀请函",
        "申请人的学术资历证明"
      ]
    },
    {
      "situation": "有偿参与活动（Permitted Paid Engagement）",
      "docs": [
        "英国邀请方出具的邀请函",
        "活动详情说明"
      ]
    },
    {
      "situation": "就医",
      "docs": [
        "英国医疗机构的预约证明",
        "医疗费用资金证明"
      ]
    }
  ],

  "supporting_docs_recommended": [
    {
      "category": "经济能力证明",
      "examples": [
        "近3-6个月银行流水",
        "工资单",
        "资产证明"
      ]
    },
    {
      "category": "在华联系证明（证明会按时离境）",
      "examples": [
        "在职证明（含职位、薪资）",
        "营业执照（自营业者）",
        "房产证明",
        "家庭关系证明"
      ]
    },
    {
      "category": "行程安排",
      "examples": [
        "详细旅行计划",
        "机票预订记录",
        "酒店预订记录"
      ]
    }
  ],

  "application_steps": [
    {
      "step": 1,
      "title": "在线填写申请表",
      "detail": "登录 gov.uk 填写标准访客签证在线申请表，可保存后继续填写"
    },
    {
      "step": 2,
      "title": "缴纳签证费",
      "detail": "在线支付签证申请费（标准6个月签证费为135英镑）"
    },
    {
      "step": 3,
      "title": "预约签证申请中心（VAC）",
      "detail": "在中国的英国签证申请中心（由TLScontact或VFS Global运营）预约采集生物特征和递交材料的时间"
    },
    {
      "step": 4,
      "title": "前往签证申请中心",
      "detail": "携带护照和所需材料前往预约的签证申请中心，采集指纹和照片（生物特征信息），当天取回护照"
    },
    {
      "step": 5,
      "title": "等待审核",
      "detail": "通常3周内收到决定；可通过邮件通知了解进度；可付费申请加急处理"
    }
  ],

  "biometrics": {
    "required": true,
    "includes": ["10指指纹", "数字照片"],
    "note": "在签证申请中心采集，当天取回护照"
  },

  "translation_requirement": {
    "required": true,
    "note": "所有非英文或威尔士语的文件须提供经认证的英文翻译件"
  },

